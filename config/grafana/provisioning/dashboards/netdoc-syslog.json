      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "calcs": [], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "none" } },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "netdoc_ch" },
          "rawSql": "SELECT toStartOfMinute(timestamp) AS time, multiIf(severity=0,'EMERGENCY',severity=1,'ALERT',severity=2,'CRITICAL',severity=3,'ERROR',severity=4,'WARNING',severity=5,'NOTICE',severity=6,'INFO','DEBUG') AS level, count() AS cnt FROM netdoc_logs.syslog WHERE timestamp >= $__fromTime AND timestamp <= $__toTime GROUP BY time, level ORDER BY time ASC",
          "refId": "A"
        }
      ],
      "title": "Logi per poziom ważności",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "netdoc_ch" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 2,
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["sum"] }, "showUnfilled": true },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "netdoc_ch" },
          "rawSql": "SELECT dictGetOrDefault('netdoc_logs.devices_dict','hostname',src_ip,src_ip) AS host, count() AS cnt FROM netdoc_logs.syslog WHERE timestamp >= $__fromTime AND timestamp <= $__toTime AND severity <= 4 GROUP BY host ORDER BY cnt DESC LIMIT 15",
          "refId": "A"
        }
      ],
      "title": "Top 15 urządzeń (WARNING+)",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "netdoc_ch" },
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 3,
      "options": { "displayMode": "gradient", "orientation": "horizontal", "reduceOptions": { "calcs": ["sum"] }, "showUnfilled": true },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "netdoc_ch" },
          "rawSql": "SELECT program, count() AS cnt FROM netdoc_logs.syslog WHERE timestamp >= $__fromTime AND timestamp <= $__toTime GROUP BY program ORDER BY cnt DESC LIMIT 15",
          "refId": "A"
        }
      ],
      "title": "Top 15 procesów",
      "type": "bargauge"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "netdoc_ch" },
