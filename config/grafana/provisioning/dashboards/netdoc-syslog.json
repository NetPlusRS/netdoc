          { "matcher": { "id": "byName", "options": "program"   }, "properties": [{ "id": "custom.width", "value": 110 }] }
        ]
      },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 16 },
      "id": 4,
      "options": { "footer": { "show": false }, "showHeader": true },
      "targets": [
        {
          "datasource": { "type": "grafana-clickhouse-datasource", "uid": "netdoc_ch" },
          "rawSql": "SELECT timestamp, src_ip, multiIf(severity=0,'EMERGENCY',severity=1,'ALERT',severity=2,'CRITICAL',severity=3,'ERROR',severity=4,'WARNING',severity=5,'NOTICE',severity=6,'INFO','DEBUG') AS severity, program, message FROM netdoc_logs.syslog WHERE timestamp >= $__fromTime AND timestamp <= $__toTime ORDER BY timestamp DESC LIMIT 500",
