          { "matcher": { "id": "byName", "options": "CRITICAL"  }, "properties": [{ "id": "color", "value": { "fixedColor": "#da3633", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WARNING"   }, "properties": [{ "id": "color", "value": { "fixedColor": "#e3b341", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "INFO"      }, "properties": [{ "id": "color", "value": { "fixedColor": "#238636", "mode": "fixed" } }] }
        ]
