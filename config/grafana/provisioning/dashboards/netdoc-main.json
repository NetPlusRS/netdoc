    {
      "id": 27,
      "type": "table",
      "title": "Otwarte podatnosci",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "datasource": {
        "type": "postgres",
        "uid": "netdoc_pg"
      },
      "targets": [
        {
          "rawSql": "SELECT\n         d.ip,\n         COALESCE(d.hostname,'—') AS hostname,\n         v.vuln_type::text AS typ_podatnosci,\n         v.severity::text AS severity,\n         v.title,\n         COALESCE(v.port::text, '—') AS port,\n         TO_CHAR(v.first_seen, 'MM-DD HH24:MI') AS wykryto,\n         TO_CHAR(v.last_seen,  'MM-DD HH24:MI') AS ostatnio\n       FROM vulnerabilities v\n       JOIN devices d ON d.id = v.device_id\n       WHERE v.is_open = true AND v.suppressed = false\n       ORDER BY\n         CASE v.severity WHEN 'critical' THEN 1 WHEN 'high' THEN 2\n                         WHEN 'medium' THEN 3 ELSE 4 END,\n         v.last_seen DESC\n       LIMIT 100",
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "netdoc_pg"
          }
        }
      ],
      "options": {
        "sortBy": [],
        "footer": {
          "show": false
        }
      },
