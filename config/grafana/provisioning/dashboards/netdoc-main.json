      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 47
      },
      "datasource": {
        "type": "postgres",
        "uid": "netdoc_pg"
      },
      "targets": [
        {
          "rawSql": "SELECT\n         TO_CHAR(d.first_seen, 'YYYY-MM-DD HH24:MI') AS odkryto,\n         d.ip,\n         COALESCE(d.hostname, '—') AS hostname,\n         COALESCE(d.vendor, '—') AS vendor,\n         COALESCE(d.device_type::text, 'unknown') AS typ,\n         CASE WHEN d.is_active THEN 'UP' ELSE 'DOWN' END AS status\n       FROM devices d\n       ORDER BY d.first_seen DESC\n       LIMIT 50",
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "netdoc_pg"
