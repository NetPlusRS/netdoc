    {
      "id": 19,
      "type": "table",
      "title": "Urzadzenia — status i szczegoly",
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "datasource": {
        "type": "postgres",
        "uid": "netdoc_pg"
      },
      "targets": [
        {
          "rawSql": "SELECT\n         d.ip,\n         COALESCE(d.hostname, '—') AS hostname,\n         COALESCE(d.vendor,   '—') AS vendor,\n         COALESCE(d.device_type::text, 'unknown') AS typ,\n         COALESCE(d.mac,      '—') AS mac,\n         CASE WHEN d.is_active THEN 'UP' ELSE 'DOWN' END AS status,\n         TO_CHAR(d.last_seen, 'YYYY-MM-DD HH24:MI') AS ostatni_kontakt,\n         COALESCE(d.os_version, '—') AS system\n       FROM devices d\n       ORDER BY d.is_active DESC, d.ip",
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "netdoc_pg"
          }
        }
      ],
      "options": {
        "sortBy": [],
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": false
          }
        },
