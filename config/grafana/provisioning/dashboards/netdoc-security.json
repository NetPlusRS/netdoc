    {
      "id": 13,
      "type": "table",
      "title": "Dzialajace credentials (potwierdzone)",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "datasource": {
        "type": "postgres",
        "uid": "netdoc_pg"
      },
      "targets": [
        {
          "rawSql": "SELECT\n         d.ip,\n         COALESCE(d.hostname,'—') AS hostname,\n         c.method::text AS metoda,\n         c.username,\n         CASE WHEN c.password_encrypted IS NOT NULL THEN '(zaszyfrowane)' ELSE '—' END AS haslo,\n         TO_CHAR(c.last_success_at,'YYYY-MM-DD HH24:MI') AS ostatni_sukces\n       FROM credentials c\n       JOIN devices d ON d.id = c.device_id\n       WHERE c.last_success_at IS NOT NULL\n       ORDER BY c.last_success_at DESC\n       LIMIT 100",
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "netdoc_pg"
          }
        }
