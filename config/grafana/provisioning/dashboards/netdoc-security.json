        "overrides": []
      }
    },
    {
      "id": 11,
      "type": "table",
      "title": "Rozwiazane (ostatnie 7 dni)",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "datasource": {
        "type": "postgres",
        "uid": "netdoc_pg"
      },
      "targets": [
        {
          "rawSql": "SELECT\n         d.ip, COALESCE(d.hostname,'—') AS hostname,\n         v.vuln_type::text AS typ, v.severity::text AS severity,\n         TO_CHAR(v.last_seen,'MM-DD HH24:MI') AS zamknieto\n       FROM vulnerabilities v\n       JOIN devices d ON d.id = v.device_id\n       WHERE v.is_open = false AND v.last_seen > NOW() - INTERVAL '7 days'\n       ORDER BY v.last_seen DESC",
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "netdoc_pg"
          }
        }
