    {
      "id": 8,
      "type": "table",
      "title": "Wszystkie otwarte podatnosci",
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "datasource": {
        "type": "postgres",
        "uid": "netdoc_pg"
      },
      "targets": [
        {
          "rawSql": "SELECT\n         d.ip,\n         COALESCE(d.hostname,'—') AS hostname,\n         COALESCE(d.vendor,'—') AS vendor,\n         v.vuln_type::text AS typ,\n         v.severity::text AS severity,\n         v.title AS opis,\n         COALESCE(v.port::text,'—') AS port,\n         COALESCE(v.evidence,'') AS dowod,\n         TO_CHAR(v.first_seen,'YYYY-MM-DD HH24:MI') AS wykryto,\n         TO_CHAR(v.last_seen, 'YYYY-MM-DD HH24:MI') AS ostatnio\n       FROM vulnerabilities v\n       JOIN devices d ON d.id = v.device_id\n       WHERE v.is_open = true AND v.suppressed = false\n       ORDER BY\n         CASE v.severity WHEN 'critical' THEN 1 WHEN 'high' THEN 2\n                         WHEN 'medium' THEN 3 ELSE 4 END,\n         v.last_seen DESC\n       LIMIT 200",
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "netdoc_pg"
          }
        }
      ],
      "options": {
        "sortBy": [],
        "footer": {
          "show": false
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "displayMode": "auto",
            "inspect": false
          }
        },
        "overrides": []
