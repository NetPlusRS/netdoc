    {
      "id": 10,
      "type": "table",
      "title": "Zaakceptowane podatnosci (suppressed)",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "postgres",
        "uid": "netdoc_pg"
      },
      "targets": [
        {
          "rawSql": "SELECT\n         d.ip, COALESCE(d.hostname,'—') AS hostname,\n         v.vuln_type::text AS typ, v.severity::text AS severity, v.title\n       FROM vulnerabilities v\n       JOIN devices d ON d.id = v.device_id\n       WHERE v.suppressed = true\n       ORDER BY d.ip",
          "format": "table",
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "netdoc_pg"
          }
        }
      ],
