# ============================================================
# NetDoc Collector — konfiguracja srodowiskowa
# Skopiuj do .env i uzupelnij wartosci
# ============================================================

# --- Database (PostgreSQL) ---
# Opcja 1: osobne zmienne (zalecane)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=netdoc
DB_USER=netdoc
DB_PASSWORD=netdoc

# Opcja 2: pelny URL (nadpisuje opcje 1 jesli ustawione)
# DB_URL=postgresql+psycopg2://netdoc:netdoc@localhost:5432/netdoc

# --- UniFi Cloud API ---
UNIFI_HOST=https://api.ui.com
UNIFI_USERNAME=twoj@email.com
UNIFI_PASSWORD=haslo

# --- Discovery ---
NETWORK_RANGES=192.168.1.0/24
SCAN_INTERVAL_MINUTES=60

# --- Bezpieczenstwo ---
# Wygeneruj: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=zmien_ten_klucz_na_losowy_ciag_znakow

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Logging ---
LOG_LEVEL=INFO
