# Prywatne notatki i koncepcje — nie na GitHub
_private/

# Srodowisko
.env
.env.local
.env.*.local

# Pro package — nie dołaczaj do Community repo
netdoc_pro/

# Wygenerowane raporty Device Passport (Pro feature) — pliki HTML per-urządzenie
device_passports/*.html

# Logi i runtime
logs/*
!logs/.gitkeep
!logs/agents/
logs/agents/*
!logs/agents/.gitkeep
*.pid
*.log

# CLI Command Reference — only partial checkpoints are excluded (HTML is tracked)
device_commands/*.partial.yaml

# CLI Extractor — proprietary extraction tool, private knowledge (results tracked, tool not)
netdoc/collector/cli_extractor.py

# Runtime flags
scan_now.flag

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# Build / dystrybucja
dist/
build/
*.egg-info/
*.egg

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Dane lokalne — runtime (nie wersjonuj)
data/*
backups/

# Zachowaj statyczne bazy danych wymagane przez skaner
# (fingerprints bannerow, producenci MAC/OUI, OID SNMP)
# Bez tych plikow skaner nie zadziala po git clone!
!data/fingerprints/
!data/fingerprints/**
!data/oui/
!data/oui/**
!data/oid/
!data/oid/**
scanner.pid
coverage.json
netdoc_fallback.db
scan_batch_status.json
scan_progress.json

# OS
.DS_Store
Thumbs.db
